{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.cv-pipeline/spec.schema.json",
  "title": "CV Pipeline Job-Ad Spec",
  "type": "object",
  "additionalProperties": true,
  "required": ["company", "role", "date_saved", "profile", "experience", "skills"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "pipeline_version": {
      "type": "string"
    },
    "evidence_snapshot": {
      "type": "string"
    },
    "created_by_model": {
      "type": "string"
    },
    "reviewed_by": {
      "type": "string"
    },
    "review_status": {
      "type": "string",
      "enum": ["draft", "reviewed", "submitted", "archived"]
    },
    "company": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "source_url": {
      "type": "string"
    },
    "date_saved": {
      "type": "string",
      "format": "date"
    },
    "ad_raw": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "role_intent": {
      "type": "object",
      "additionalProperties": true
    },
    "narrative_mode": {
      "type": "string"
    },
    "gap_framing": {
      "type": "object",
      "additionalProperties": true
    },
    "signal_density": {
      "type": "object",
      "additionalProperties": true
    },
    "section_order": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["profile", "experience", "projects", "skills", "education"]
      },
      "uniqueItems": true
    },
    "education_bullets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "experience": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/experience_role"
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/project_selection"
      }
    },
    "skills": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/skill_category"
          }
        }
      ]
    },
    "cover_letter": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "experience_role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bank", "title", "dates", "employer", "location", "bullets"],
      "properties": {
        "bank": {
          "type": "string",
          "enum": ["soniq", "csiro"]
        },
        "title": {
          "type": "string"
        },
        "dates": {
          "type": "string"
        },
        "employer": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "bullets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "project_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "bullets"],
      "properties": {
        "id": {
          "type": "string"
        },
        "bullets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "skill_category": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "items"],
      "properties": {
        "category": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
